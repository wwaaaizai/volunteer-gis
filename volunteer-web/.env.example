# 环境变量模板。复制为 .env.local 并填入真实值（.env.local 已被 gitignore）。

# 是否启用前端 MSW Mock（true=纯前端运行；false=连真实后端 http://localhost:8080）
VITE_USE_MOCK=false

# 天地图 API Key（申请：https://console.tianditu.gov.cn/）
VITE_TIANDITU_KEY=

# GeoServer 地址（供 vite 代理使用，默认 http://localhost:9091）
VITE_GEOSERVER_URL=http://localhost:9091
