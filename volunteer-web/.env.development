# 开发环境默认配置（会被提交，提供开箱即用的演示体验）
# 覆盖真实/轮换后的密钥请用 .env.local（已被 .gitignore 忽略）

# 是否启用前端 MSW Mock（true=纯前端运行，无需后端/MySQL；false=连真实后端）
VITE_USE_MOCK=false

# 天地图 API Key
VITE_TIANDITU_KEY=0309511b084b5502995c717d812db55c

# GeoServer 地址（供 vite 代理使用）
# 默认指向本机 localhost:9091；其他设备演示时在 .env.local 中改为 http://<主机IP>:9091
VITE_GEOSERVER_URL=http://localhost:9091
